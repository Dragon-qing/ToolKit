{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "mkdir",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}" //已执行程序或脚本的当前工作目录，设置当前项目文件夹
            },
            "command": "mkdir", //命令
            "args": [ //命令后面跟的参数
                "-Force",
                "build"
            ]
        },
        {
            "label": "qmake-debug",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "command": "D:/Qt/5.14.2/5.14.2/msvc2017_64/bin/qmake.exe", // 根据实际修改路径
            "args": [
                "./toolkits.pro",
                "-spec",
                "win32-msvc",
                "\"CONFIG+=debug\"",
                "\"CONFIG+=qml_debug\"" 
            ],
            "dependsOn": [
                "mkdir"
            ]
        },
        {
            "label": "make-debug",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "command": ".\\vscode_make.bat",
            "dependsOn": [
                "qmake-debug"
            ]
        },
        {
            "label": "run-debug",
            "type": "process", //运行就不能选择shell执行了，要选择process
            "options": {
                "cwd": "${workspaceFolder}/bin" 
            },
            "command": "toolkits.exe", 
            "dependsOn": [
                "make-debug"
            ]
        },
        {
            "label": "clean",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "command": "D:/Qt/QtCreator13.0.2/bin/jom/jom.exe", // 根据实际修改路径
            "args": [
                "clean"
            ]
        }
    ]
}